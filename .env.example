# Backend
# 模型服务和 API key 由各账号在左侧“模型配置”中保存。
BID_DESIGN_WRITER_SKILL_DIR=
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# 默认允许 localhost / 127.0.0.1 / [::1] 任意端口和 app://frontend。
FRONTEND_ORIGIN_REGEX=^(https?://(localhost|127\.0\.0\.1|\[::1\])(:\d+)?|app://frontend|null)$
AGENT_HOST=127.0.0.1
AGENT_PORT=8765

# Local security
# Electron 会自动生成 APP_AUTH_SECRET 并注入本机后端；浏览器开发模式通常无需手动配置。
APP_AUTH_SECRET=

# Tavily web search
TAVILY_API_KEY=
TAVILY_SEARCH_URL=https://api.tavily.com/search
TAVILY_SEARCH_TIMEOUT=20
WEB_SEARCH_MAX_RESULTS=5
TAVILY_SEARCH_DEPTH=basic

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8765
