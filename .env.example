# Backend
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-pro
BID_DESIGN_WRITER_SKILL_DIR=
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# 默认允许 localhost / 127.0.0.1 / [::1] 任意端口和 app://frontend。
FRONTEND_ORIGIN_REGEX=^(https?://(localhost|127\\.0\\.0\\.1|\\[::1\\])(:\\d+)?|app://frontend|null)$
AGENT_HOST=127.0.0.1
AGENT_PORT=8765

# Local security
# Electron 会自动生成 APP_AUTH_SECRET 并注入本机后端；浏览器开发模式通常无需手动配置。
APP_AUTH_SECRET=
# 仅开发/测试使用。启用后，当系统钥匙串不可用时，模型 API key 会回退到进程内存。
AI_WORKBENCH_ALLOW_MEMORY_CREDENTIALS=false

# Behavior report email. 163 邮箱通常需要使用 SMTP 授权码作为 SMTP_PASSWORD。
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
BEHAVIOR_REPORT_RECIPIENTS=le263687605@163.com

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8765
